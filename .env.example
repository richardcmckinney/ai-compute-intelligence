# ACI Platform - Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.

# Neo4j (graph store, Tier 1)
ACI_NEO4J_URI=bolt://localhost:7687
ACI_NEO4J_USER=neo4j
ACI_NEO4J_PASSWORD=

# Redis (attribution index, Tier 2)
ACI_REDIS_URL=redis://localhost:6379/0

# Kafka (event bus)
ACI_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Platform
ACI_ENVIRONMENT=development
ACI_TENANT_ID=

# Interceptor
ACI_INTERCEPTOR_TIMEOUT_MS=20
ACI_INTERCEPTOR_TOTAL_BUDGET_MS=50

# Federated Benchmarking
ACI_FBP_EPSILON_TOTAL_QUARTERLY=4.0
ACI_FBP_USE_SECURE_NOISE=false
