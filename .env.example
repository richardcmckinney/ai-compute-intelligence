# ACI Platform - Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.

# Neo4j (graph store, Tier 1)
ACI_NEO4J_URI=bolt://localhost:7687
ACI_NEO4J_USER=neo4j
ACI_NEO4J_PASSWORD=change-me

# Redis (attribution index, Tier 2)
ACI_REDIS_URL=redis://localhost:6379/0

# Kafka (event bus)
ACI_KAFKA_BOOTSTRAP=localhost:9092

# Platform
ACI_ENVIRONMENT=development
ACI_TENANT_ID=dev-local
ACI_RUNTIME_ROLE=all
ACI_UVICORN_WORKERS=1
ACI_INTERCEPTOR_MODE=advisory
ACI_GRAPH_BACKEND=memory
ACI_EVENT_BUS_BACKEND=memory
ACI_INDEX_BACKEND=memory
ACI_INTERCEPTOR_CIRCUIT_STATE_BACKEND=local
ACI_INDEX_REDIS_TTL_S=1800
ACI_API_INGEST_RATE_LIMIT_PER_MINUTE=600
ACI_API_INGEST_MAX_BATCH_SIZE=1000
ACI_API_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ACI_API_CORS_ALLOW_CREDENTIALS=false

# Interceptor
ACI_INTERCEPTOR_TIMEOUT_MS=20
ACI_INTERCEPTOR_TOTAL_BUDGET_MS=50
ACI_INTERCEPTOR_POLICY_TIMEOUT_MS=15
ACI_INTERCEPTOR_ACTIVE_LITE_MIN_CONFIDENCE=0.90
ACI_INTERCEPTOR_ACTIVE_LITE_GATE_MIN_CONFIDENCE=0.95

# API authentication (service-to-service JWT)
ACI_AUTH_ENABLED=true
ACI_AUTH_ALLOW_DEV_BYPASS=true
ACI_AUTH_JWT_ALGORITHM=HS256
ACI_AUTH_JWT_ISSUER=aci-control-plane
ACI_AUTH_JWT_AUDIENCE=aci-api
ACI_AUTH_JWT_HS256_SECRET=replace-with-strong-secret
ACI_AUTH_REQUIRED_SCOPE=aci.api
ACI_AUTH_TENANT_CLAIM=tenant_id
ACI_AUTH_CLOCK_SKEW_SECONDS=60

# Federated Benchmarking
ACI_FBP_EPSILON_TOTAL_QUARTERLY=4.0
ACI_FBP_USE_SECURE_NOISE=true

# Demo profile (recommended for investor walkthroughs)
# ACI_ENVIRONMENT=demo
# ACI_GRAPH_BACKEND=memory
# ACI_EVENT_BUS_BACKEND=memory
# ACI_INDEX_BACKEND=memory
# ACI_INTERCEPTOR_CIRCUIT_STATE_BACKEND=local
